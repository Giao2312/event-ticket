extends ../../../layout

block content
  - 
    // Bộ lọc đường dẫn ảnh ngay trong Pug để hiển thị lần đầu
    const getImageUrl = (path) => {
      if (!path || path.length < 2) return '/events/images/placeholder.jpg';
      if (path.includes('/events/')) return path;
      if (path.startsWith('images/')) return '/events/' + path;
      return path;
    };

  section.position-relative.py-5.bg-light
    div.container
      div.row.align-items-center
        div.col-lg-6
          span.badge.bg-primary.mb-3= event.category || 'Sự kiện'
          h1.fw-bold.display-4.mb-4= event.name
          div.d-flex.flex-wrap.gap-3.mb-4
            span.text-muted 
              i.fas.fa-calendar-alt.me-2
              = new Date(event.date).toLocaleDateString('vi-VN')
            span.text-muted 
              i.fas.fa-map-marker-alt.me-2
              = event.location || event.venue || 'Chưa xác định'
        div.col-lg-6
          img.img-fluid.rounded-4.shadow-lg#eventImage(
            src=getImageUrl(event.image), 
            onerror="this.src='/events/images/placeholder.jpg'"
          )

  section.py-5
    div.container
      div.row.g-5
        div.col-lg-7
          h4.fw-bold.mb-3 Giới thiệu sự kiện
          p.text-muted.lh-lg= event.description
          
          hr.my-5
          h4.fw-bold.mb-3 Ban tổ chức
          div.d-flex.align-items-center.p-3.border.rounded-3
            img.rounded-circle.me-3(
              src="/events/images/default-avatar.jpg", 
              width="50", height="50", 
              style="object-fit: cover;",
              onerror="this.src='/events/images/placeholder.jpg'"
            )
            div
              h6.mb-0= event.organizerName || "Ban tổ chức"
              small.text-muted Đơn vị xác thực

        div.col-lg-5
          div.card.shadow-sm.border-0.rounded-4.sticky-top(style="top: 100px;")
            div.card-body.p-4
              h5.fw-bold.mb-4 Thông tin đặt vé
              form#bookingForm
                div.mb-3
                  label.form-label Loại vé
                    select.form-select.form-select-lg#ticketType(name="ticketTypeId")
                      each type in ticketTypes || []
                        option(
                          value=type._id, 
                          data-price=type.price, 
                          data-available=(type.quantity - type.sold - type.holded)
                        )
                          | #{type.type} - #{type.price.toLocaleString('vi-VN')} VNĐ
                
                div.mb-3
                  label.form-label Số lượng
                  div.input-group.input-group-lg
                    button.btn.btn-outline-secondary#btnMinus(type="button") -
                    input.form-control.text-center#quantity(
                      type="number" value="1" min="1" readonly 
                      style="color: #000 !important; background-color: #fff !important;")
                    button.btn.btn-outline-secondary#btnPlus(type="button") +
                
                div.d-flex.justify-content-between.align-items-center.bg-light.p-3.rounded-3.mb-4
                  span.fw-bold Tổng cộng
                  h4#totalPrice.text-primary.mb-0 0đ
                
                button.btn.btn-lg.btn-primary.w-100.rounded-3#buyBtn(type="button") Đặt vé ngay

  section.py-5
    hr.my-5
    div.related-events-section.pb-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h4.fw-bold.mb-0 Có thể bạn sẽ thích
        a.btn.btn-sm.btn-outline-primary.rounded-pill(href="/events") Xem tất cả
      
      div.row.g-4#eventsGrid
        if events && events.length > 0
          each event in events
            - const price = event.minPrice ? event.minPrice.toLocaleString('vi-VN') + 'đ' : 'Liên hệ'
            - const date = event.date ? new Date(event.date).toLocaleDateString('vi-VN') : 'Chưa xác định'
            - const img = event.image || '/images/placeholder.jpg'

            a.text-decoration-none(href=`/events/${event._id}`)  // ← Bọc toàn bộ card trong thẻ <a>
              div.col-12.col-md-6.col-lg-3.event-item
                div.card.h-100.border-0.shadow-sm.overflow-hidden.hover-shadow
                  img.card-img-top(src=img alt=event.name style="height: 220px; object-fit: cover;")
                  div.card-body.d-flex.flex-column
                    span.badge.bg-primary.mb-2.align-self-start= event.category || 'Nổi bật'
                    h5.card-title.fw-bold= event.name || 'Tên sự kiện'
                    p.text-muted.small.mb-1
                      i.fas.fa-calendar-alt.me-2
                      | #{date} • #{event.time || 'Giờ TBC'}
                    p.text-muted.small.mb-3
                      i.fas.fa-map-marker-alt.me-2
                      | #{event.location || 'Địa điểm TBC'}
                    
                    div.mt-auto.d-flex.justify-content-between.align-items-center
                      span.text-primary.fw-bold= price
                      span.btn.btn-sm.btn-outline-primary Chi tiết  // ← Giữ nút này để UX rõ ràng, nhưng không cần href nữa
        else
          div.col-12.text-center.py-5
            p.text-muted Hiện chưa có sự kiện nào được đăng tải.      

  block append scripts
    script.
      // Đảm bảo script chạy sau khi DOM load xong để tránh lỗi ReferenceError
      document.addEventListener('DOMContentLoaded', () => {
        const ticketSelect = document.getElementById('ticketType');
        const qtyInput = document.getElementById('quantity');
        const totalEl = document.getElementById('totalPrice');
        const btnPlus = document.getElementById('btnPlus');
        const btnMinus = document.getElementById('btnMinus');
        const buyBtn = document.getElementById('buyBtn');
        const bookingForm = document.getElementById('bookingForm');

        // Tránh bind lặp listener nếu script bị chạy lại
        if (!ticketSelect || !qtyInput || !totalEl || !btnPlus || !btnMinus || !buyBtn || !bookingForm) return;
        if (bookingForm.dataset.bound === '1') return;
        bookingForm.dataset.bound = '1';

        const getCurrentOption = () => ticketSelect.options[ticketSelect.selectedIndex] || null;
        const getQty = () => Number.parseInt(qtyInput.value, 10) || 1;
        const getPrice = () => {
          const option = getCurrentOption();
          return option ? (Number.parseInt(option.dataset.price, 10) || 0) : 0;
        };
        const getMaxAvailable = () => {
          const option = getCurrentOption();
          const max = option ? Number.parseInt(option.dataset.available, 10) : 0;
          return Number.isNaN(max) ? 0 : Math.max(0, max);
        };

        const updatePrice = () => {
          const price = getPrice();
          const qty = getQty();
          totalEl.textContent = (price * qty).toLocaleString('vi-VN') + 'đ';
        };

        // Xử lý nút tăng/giảm số lượng qua Event Listener
        btnPlus.addEventListener('click', () => {
          const max = getMaxAvailable();
          let current = getQty();
          if (current < max) {
            qtyInput.value = String(current + 1);
            updatePrice();
          }
        });

        btnMinus.addEventListener('click', () => {
          let current = getQty();
          if (current > 1) {
            qtyInput.value = String(current - 1);
            updatePrice();
          }
        });

        ticketSelect.addEventListener('change', () => {
          const max = getMaxAvailable();
          qtyInput.value = String(max > 0 ? 1 : 0);
          updatePrice();
        });

        // Xử lý đặt vé
        buyBtn.addEventListener('click', async () => {
          const isLoggedIn = #{JSON.stringify(!!user)};
          if (!isLoggedIn) {
            alert('Vui lòng đăng nhập để tiếp tục');
            return window.location.href = '/login';
          }

          const payload = {
            items: [{
              ticketTypeId: ticketSelect.value, // ID của loại vé đã chọn
              quantity: getQty()
            }],
            paymentMethod: 'momo' // Demo: chỉ dùng MoMo
          };

          try {
            buyBtn.disabled = true;
            buyBtn.textContent = 'Đang giữ chỗ...';

            const res = await fetch('/api/orders/create', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(payload)
            });

            const data = await res.json();
            if (data.success) {
              // Sau khi tạo đơn hàng thành công, chuyển đến trang thanh toán riêng
              window.location.href = `/checkout/${data.orderId}`;
            } else {
              alert(data.message || 'Lỗi đặt vé');
              buyBtn.disabled = false;
            }
          } catch (err) {
            console.error(err);
            buyBtn.disabled = false;
          }
        });

        // Khởi tạo giá tiền ban đầu
        updatePrice();
      });

