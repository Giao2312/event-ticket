extends ../../../layout

block content
  section.py-5.bg-light
    div.container
      div.row.g-5
        div.col-lg-8
          img.img-fluid.rounded.shadow-lg(
            src= (event && event.image) ? event.image : 'https://placehold.co/1200x600',
            alt= (event && event.name) ? event.name : 'Sự kiện',
            style="height: 500px; width: 100%; object-fit: cover;"
          )
          
          h1.fw-bold.mt-4= (event && event.name) ? event.name : 'Sự kiện không xác định'
          
          div.d-flex.gap-4.mb-4
            span
              i.fas.fa-calendar-alt.me-2.text-primary
              if event && event.date
                | #{event.date.toLocaleDateString('vi-VN')} • #{event.time}
              else
                | Đang cập nhật thời gian
            span
              i.fas.fa-map-marker-alt.me-2.text-primary
              | #{event ? event.location : 'Chưa có địa điểm'}
          
          p.lead= event ? event.description : 'Không có mô tả cho sự kiện này.'

        div.col-lg-4
          div.card.shadow-lg.sticky-top(style="top: 100px;")
            div.card-body
              h4.fw-bold.mb-4 Chọn vé
              div.mb-4
                label.fw-medium Loại vé
                select.form-select
                  if event && event.ticketTypes
                    each type in event.ticketTypes
                      option(value=type._id) #{type.name} - #{type.price.toLocaleString()}đ (Còn #{type.available || 0} vé)
                  else
                    option(disabled) Hiện tại không có vé
              
              div.mb-4
                label.fw-medium Số lượng
                input.form-control(type="number" min="1" value="1")
              
              div.d-flex.justify-content-between.align-items-center.mb-4
                h5.fw-bold Tổng tiền
                h4.text-primary 0đ
              
              button.btn.btn-primary.btn-lg.w-100 Đặt vé ngay
              p.text-muted.small.mt-3
                i.fas.fa-clock.me-1 Giữ chỗ trong 15 phút

  section.py-5.bg-white
    div.container
      h3.fw-bold.mb-4 Sự kiện liên quan
      div.row.g-4
