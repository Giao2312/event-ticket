header.sticky-top.z-50.border-bottom.bg-dark.bg-opacity-80.backdrop-blur-xl
  div.container.d-flex.align-items-center.justify-content-between.h-16

    nav.d-none.d-md-flex.align-items-center.gap-6 
      a(href="/" class="d-flex.align-items-center.gap-2.fw-bold.text-xl.text-white.text-decoration-none")
        div.d-flex.align-items-center.justify-content-center.rounded-circle.bg-gradient-hero.w-9.h-9
          i.fas.fa-ticket-alt.text-white.fs-5
      a(href="/" class="d-flex.align-items-center.gap-2.fw-bold.text-xl.text-white.text-decoration-none") EventVé


    nav.d-none.d-md-flex.align-items-center.gap-4
      a(href="/events" class="text-sm.fw-medium.text-white.text-opacity-75.hover-text-white.transition") Sự kiện
      a(href="/events?category=am-nhac" class="text-sm.fw-medium.text-white.text-opacity-75.hover-text-white.transition") Âm nhạc
      a(href="/events?category=the-thao" class="text-sm.fw-medium.text-white.text-opacity-75.hover-text-white.transition") Thể thao
      a(href="/events?category=workshop" class="text-sm.fw-medium.text-white.text-opacity-75.hover-text-white.transition") Workshop
      a(href="/events?category=other" class="text-sm.fw-medium.text-white.text-opacity-75.hover-text-white.transition") Khác


    div(class="hidden md:flex items-center gap-3")
      if user
        a(href="/profile" class="d-flex align-items-center gap-2 text-white text-decoration-none")
          div(class="w-8 h-8 bg-white bg-opacity-20 rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm")
            | #{user.name[0].toUpperCase()}
          span(class="text-sm fw-medium") #{user.name}
      else
        button.btn.btn-outline-light.btn-sm.px-4.py-2.me-2(type="button" onclick="location.href='/login'")
          | Đăng nhập
        button.btn.btn-outline-light.btn-sm.px-4.py-2.me-2(type="button" onclick="location.href='/register'")
          | Đăng ký

    button.btn.btn-link.text-white.d-md-none.fs-4(type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu")
      i.fas.fa-bars

  // Mobile menu (collapse)
  div#mobileMenu.collapse.d-md-none.bg-dark.border-top.border-white.border-opacity-10
    div.container.py-3
      nav.d-flex.flex-column.gap-3
        a(href="/events" class="text-white.text-decoration-none.fw-medium") Sự kiện
        a(href="/events?category=am-nhac" class="text-white.text-decoration-none.fw-medium") Âm nhạc
        a(href="/events?category=the-thao" class="text-white.text-decoration-none.fw-medium") Thể thao
        a(href="/events?category=workshop" class="text-white.text-decoration-none.fw-medium") Workshop
        a(href="/events?category=other" class="text-white.text-decoration-none.fw-medium") Khác
        if user
          a(href="/profile" class="text-white.text-decoration-none.fw-medium") Hồ sơ
          a(href="/logout" class="text-white.text-decoration-none.fw-medium") Đăng xuất
        else
          a(href="/login" class="btn.btn-outline-light.btn-sm.w-100.mb-2") Đăng nhập
          a(href="/register" class="btn.btn-primary.btn-sm.bg-gradient-hero.w-100") Đăng ký