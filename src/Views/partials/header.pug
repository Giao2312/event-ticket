// views/partials/header.pug
header 
  div(class="bg-[#00b14f] text-white py-3")
    div(class="container mx-auto px-4 flex items-center justify-between")
      // Logo - thêm icon SVG để đẹp hơn
      a(href="/" class="flex items-center gap-2 group")
        svg(class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24")
          path(d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5")
        span(class="font-black text-3xl tracking-tighter") ticketpro
        span(class="text-xl mb-1") 🌸

      // Search Bar - cải thiện responsive (hiện icon search trên mobile)
      div(class="flex-grow max-w-2xl mx-8 hidden lg:flex bg-white rounded-md overflow-hidden shadow-sm items-center")
        div(class="pl-4 pr-2")
          svg(class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z")
        input(type="text" placeholder="Bạn tìm gì hôm nay?" class="flex-grow bg-transparent text-gray-800 py-3 outline-none text-sm font-medium")
        div(class="h-6 w-[1px] bg-gray-200 mx-2")
        button(class="px-6 py-3 text-gray-700 text-sm font-bold hover:bg-gray-50 transition-colors") Tìm kiếm

      // Mobile search icon
      button(class="lg:hidden text-white focus:outline-none")
        i(class="fas fa-search text-xl")

      // Right Actions - giữ nguyên + thêm cart icon
      div(class="flex items-center gap-6")
        // Cart icon (giỏ vé tạm)
        a(href="/cart" class="relative text-white hover:opacity-80 transition-opacity")
          i(class="fas fa-shopping-cart text-xl")
          if cartCount > 0
            span(class="absolute -top-2 -right-2 bg-red-500 text-white text-xs rounded-full px-1.5 py-0.5") #{cartCount}

        // Create Event button
        button(class="hidden xl:block border border-white/80 px-6 py-2 rounded-full text-sm font-bold hover:bg-white hover:text-[#00b14f] transition-all")
          | Tạo sự kiện

        // My Tickets
        a(href="/my-tickets" class="flex items-center gap-2 text-sm font-bold hover:opacity-80 transition-opacity")
          svg(class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z")
          span Vé của tôi

        // User Auth
        if user
          a(href="/profile" class="flex items-center gap-2 group")
            span(class="text-sm font-bold group-hover:underline") #{user.name}
            div(class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-black text-xs")
              | #{user.name[0]}
        else
          a(href="/login" class="text-sm font-bold hover:underline whitespace-nowrap")
            | Đăng nhập | Đăng ký

        // Language (giữ nguyên)
        div(class="flex items-center gap-1 cursor-pointer hover:opacity-80 transition-opacity ml-2")
          span.text-2xl 🇻🇳
          svg(class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20")
            path(d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z")

  // Navigation Bar (giữ nguyên, nhưng có thể lấy danh mục từ DB sau)
  nav(class="bg-[#1a1a1a] text-white overflow-x-auto no-scrollbar")
    div(class="container mx-auto px-4")
      ul(class="flex items-center justify-center gap-10 py-4 text-sm font-medium whitespace-nowrap")
        li: a(href="/category/nhac-song" class="hover:text-[#00b14f] transition-colors") Nhạc sống
        li: a(href="/category/san-khau" class="hover:text-[#00b14f] transition-colors") Sân khấu & Nghệ thuật
        li: a(href="/category/the-thao" class="hover:text-[#00b14f] transition-colors") Thể thao
        li: a(href="/category/hoi-thao" class="hover:text-[#00b14f] transition-colors") Hội thảo & Workshop
        li: a(href="/category/trai-nghiem" class="hover:text-[#00b14f] transition-colors") Tham quan & Trải nghiệm
        li: a(href="/category/khac" class="hover:text-[#00b14f] transition-colors") Khác
        li: a(href="/category/ve-ban-lai" class="hover:text-[#00b14f] transition-colors") Vé bán lại