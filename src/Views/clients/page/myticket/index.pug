extends ../../../layout

block content
  section.py-5.bg-light
    div.container
      h1.fw-bold.mb-5 Vé của tôi

      if tickets && tickets.length > 0
        each ticket in tickets
          div.card.shadow-lg.mb-4.border-0
            div.card-body
              div.row.align-items-center
                div.col-md-3
                  img.img-fluid.rounded(src=ticket.event.image || 'https://placehold.co/300x200' alt=ticket.event.name style="height: 150px; object-fit: cover;")
                div.col-md-6
                  h4.fw-bold= ticket.event.name
                  p.text-muted
                    i.fas.fa-calendar-alt.me-2
                    | #{ticket.event.date.toLocaleDateString('vi-VN')} • #{ticket.event.location}
                  p.text-muted
                    i.fas.fa-ticket-alt.me-2
                    | Loại vé: #{ticket.type} • Số lượng: #{ticket.quantity}
                div.col-md-3.text-end
                  h5.text-primary.fw-bold #{ticket.price.toLocaleString()}đ
                  span.badge.bg-success Đã sử dụng
                  a.btn.btn-outline-primary.mt-3(href=`/tickets/${ticket._id}`) Xem vé
      else
        div.alert.alert-info.text-center Bạn chưa có vé nào. 
          a(href="/events") Khám phá sự kiện ngay!