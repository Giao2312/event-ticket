
header.sticky-top.z-50.border-bottom.bg-white
  div.container.h-16.d-flex.align-items-center.justify-content-between
    

    a(href="/" class="d-flex align-items-center gap-2 fw-bold text-xl text-dark text-decoration-none")
      div.d-flex.align-items-center.justify-content-center.rounded-circle.bg-gradient-hero.w-9.h-9
        i.fas.fa-ticket-alt.text-white.fs-5
      span EventVé


    form.d-none.d-md-flex.align-items-center.mx-4.flex-grow-1.justify-content-center(action="/events" method="GET")
      div.d-flex.align-items-center.gap-2.bg-white.border.rounded-pill.px-3(style="width: 50%; min-width: 280px; max-width: 520px;")
        i.fas.fa-search.text-muted
        input.form-control.border-0.shadow-none.flex-grow-1(type="text" name="search" placeholder="Tìm sự kiện, nghệ sĩ, địa điểm...")

    div.d-none.d-md-flex.align-items-center.gap-3
      if user && (user.role || '').toLowerCase() === 'organizer'
        a.btn.btn-primary.btn-sm.px-4(href="/organizer/create-event") Tạo sự kiện
      else
        a.btn.btn-outline-primary.btn-sm.px-4(href="/become-organizer") Trở thành nhà tổ chức
      if user
        div.dropdown
          a.d-flex.align-items-center.gap-2.text-dark.text-decoration-none(href="#" data-bs-toggle="dropdown")
            div.w-8.h-8.rounded-circle.overflow-hidden.shadow-sm
              img.w-100.h-100.object-cover(src=user.avatar || '/events/images/default-avatar.jpg', alt=user.name)
            span.text-sm.fw-medium #{user.name}
          ul.dropdown-menu.dropdown-menu-end
            - const role = (user.role || '').toLowerCase()
            if role === 'admin' 
              li: h6.dropdown-header.text-danger.fw-bold Quản trị hệ thống
              li: a.dropdown-item(href="/admin/dashboard") Bảng điều khiển Admin
              li: a.dropdown-item(href="/admin/dashboard/events") Quản lý sự kiện
              li: a.dropdown-item(href="/admin/dashboard/users") Quản lý người dùng
              li: hr.dropdown-divider

            else if role === 'organizer'
              li: h6.dropdown-header.text-primary.fw-bold Quản lý
              li: a.dropdown-item(href="/organizer/dashboard") Bảng điều khiển
              li: a.dropdown-item(href="/organizer/create-event") Tạo sự kiện
              li: a.dropdown-item(href="/organizer/orders") Quản lý đơn hàng
              li: hr.dropdown-divider
            li: a.dropdown-item(href="/profile") Hồ sơ cá nhân
            li: a.dropdown-item(href="/my-tickets") Vé của tôi
            li: hr.dropdown-divider
            li: button.dropdown-item.text-danger(onclick="handleLogout()") Đăng xuất
      else
        a.btn.btn-outline-secondary.btn-sm.px-4(href="/login") Đăng nhập
        a.btn.btn-primary.btn-sm.px-4(href="/register") Đăng ký


    button.btn.btn-link.text-dark.d-md-none.fs-4(type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu")
      i.fas.fa-bars


  div#mobileMenu.collapse.d-md-none.bg-white.border-top
    div.container.py-3
      nav.d-flex.flex-column.gap-3
        form.d-flex.align-items-center.gap-2(action="/events" method="GET")
          i.fas.fa-search.text-muted
          input.form-control(type="text" name="search" placeholder="Tìm sự kiện...")
        if user && (user.role || '').toLowerCase() === 'organizer'
          a.text-dark.text-decoration-none(href="/organizer/create-event") Tạo sự kiện
        else
          a.text-dark.text-decoration-none(href="/become-organizer") Trở thành nhà tổ chức
        if user
          if user.role === 'admin'
            hr.my-1.border-white.border-opacity-25
            a.text-danger.fw-bold(href="/admin/dashboard") Quản trị hệ thống
          else if isOrganizer
            hr.my-1.border-white.border-opacity-25
            a.text-primary.fw-bold(href="/organizer/dashboard") Quản lý sự kiện
            a.text-dark(href="/organizer/orders") Đơn hàng khách mua
          a.text-dark(href="/profile") Hồ sơ cá nhân
          a.text-dark(href="/my-tickets") Vé của tôi
          button.btn.btn-outline-danger.w-100(onclick="handleLogout()") Đăng xuất
        else
          a.btn.btn-outline-secondary.w-100(href="/login") Đăng nhập
          a.btn.btn-primary.w-100(href="/register") Đăng ký

