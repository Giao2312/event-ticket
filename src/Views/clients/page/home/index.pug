block scripts
  script.

    const originalFetch = window.fetch;
    window.fetch = async (url, options = {}) => {
      const token = localStorage.getItem('token');
      if (token) {
        options.headers = {
          ...options.headers,
          Authorization: `Bearer ${token}`
        };
      }
      return originalFetch(url, options);
    };

    document.addEventListener('DOMContentLoaded', async () => {
      const featuredContainer = document.getElementById('featuredEvents');
      const upcomingContainer = document.getElementById('upcomingEvents');

      // Hàm xử lý ảnh tập trung (Helper)
      const getImageUrl = (imagePath) => {
        if (!imagePath) return '/events/images/placeholder.jpg';
        if (imagePath.includes('/events/')) return imagePath;
        if (imagePath.startsWith('images/')) return '/events/' + imagePath;
        return '/events/images/placeholder.jpg';
      };

      try {
        const res = await fetch('/api/events/list'); 
        if (!res.ok) throw new Error('Không thể tải sự kiện');
        
        const events = await res.json(); 
        if (!Array.isArray(events)) throw new Error('Dữ liệu không hợp lệ');

        const featuredEvents = events.filter(e => e.featured).slice(0, 4);
        const now = new Date();
        const upcomingEvents = events
          .filter(e => new Date(e.date) > now)
          .sort((a, b) => new Date(a.date) - new Date(b.date))
          .slice(0, 4);

        // Render Featured
        if (featuredContainer) {
          // Truyền đúng image vào hàm renderCard
          featuredContainer.innerHTML = featuredEvents.map(e => renderCard(e, 'Nổi bật', 'bg-primary', e.image)).join('');
        }

        // Render Upcoming
        if (upcomingContainer) {
          upcomingContainer.innerHTML = upcomingEvents.map(event => {
            const imageSrc = getImageUrl(event.image);
            let dateStr = event.date ? new Date(event.date).toLocaleDateString('vi-VN') : 'Chưa xác định';
            
            return `
              <div class="col-md-6 col-lg-3">
                <div class="card bg-dark text-white border-0 shadow-lg overflow-hidden">
                  <img src="${imageSrc}" onerror="this.onerror=null; this.src='/events/images/placeholder.jpg';" class="card-img-top" style="height: 200px; object-fit: cover;">
                  <div class="card-body">
                    <span class="badge bg-secondary me-2">Sắp diễn ra</span>
                    <h5 class="card-title mt-2">${event.name}</h5>
                    <p class="card-text small text-white-50">${dateStr} • ${event.time || 'Chưa có giờ'}</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                      <span class="fw-bold text-primary">Từ ${event.minPrice?.toLocaleString('vi-VN') || '0'}đ</span>
                      <a href="/events/${event._id}" class="btn btn-sm btn-outline-light">Xem chi tiết</a>
                    </div>
                  </div>
                </div>
              </div>`;
          }).join('');
        }

      } catch (err) {
        console.error('Lỗi:', err);
      }
    });


      const renderCard = (event, badgeText, badgeClass, imagePath ) => {
        const imageSrc = getImageUrl(imagePath);
        return `
          <div class="col-md-6 col-lg-3">
            <div class="card bg-dark text-white border-0 shadow-lg h-100">
              <img src="${imageSrc}"  onerror="this.onerror=null; this.src='/events/images/placeholder.jpg';" class="card-img-top" style="height: 200px; object-fit: cover;">
              <div class="card-body">
                <span class="badge ${badgeClass} mb-2">${badgeText}</span>
                <h5 class="card-title">${event.name}</h5>
                <a href="/events/${event._id}" class="btn btn-sm btn-outline-light">Chi tiết</a>
              </div>
            </div>
          </div>`;
      };
              
        