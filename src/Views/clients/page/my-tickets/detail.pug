extends ../../../layout

block content
  section.py-5.bg-light
    div.container
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1.fw-bold.mb-0 Chi tiết vé
        a.btn.btn-outline-secondary(href="/my-tickets") Quay lại danh sách vé

      div.row.g-4
        div.col-lg-7
          div.card.border-0.shadow-sm.h-100
            div.card-body.p-4
              //- Fixed Optional Chaining
              h4.fw-bold.mb-3= (ticket.event && ticket.event.name) ? ticket.event.name : "Sự kiện"
              
              p.text-muted.mb-2
                i.fas.fa-calendar-alt.me-2
                //- Fixed Optional Chaining
                | #{(ticket.event && ticket.event.date) ? new Date(ticket.event.date).toLocaleDateString('vi-VN') : 'Chưa xác định'}#{(ticket.event && ticket.event.time) ? ' • ' + ticket.event.time : ''}
              
              p.text-muted.mb-3
                i.fas.fa-map-marker-alt.me-2
                //- Fixed Optional Chaining
                | #{(ticket.event && ticket.event.location) ? ticket.event.location : 'Chưa xác định'}
              
              //- Fixed Optional Chaining
              if ticket.event && ticket.event.image
                img.img-fluid.rounded(src=ticket.event.image alt=(ticket.event.name || "Sự kiện") style="max-height: 260px; object-fit: cover; width: 100%;")

              hr.my-4
              div.row.g-3
                div.col-md-6
                  div.text-muted.small Loại vé
                  div.fw-semibold= ticket.ticketType
                div.col-md-6
                  div.text-muted.small Số lượng
                  div.fw-semibold= ticket.quantity
                div.col-md-6
                  div.text-muted.small Giá
                  div.fw-semibold.text-primary #{Number(ticket.price || 0).toLocaleString('vi-VN')}đ
                div.col-md-6
                  div.text-muted.small Trạng thái
                  span.badge(class=ticket.status === 'paid' ? 'bg-success' : ticket.status === 'pending' ? 'bg-warning text-dark' : 'bg-secondary')
                    = ticket.status === 'paid' ? 'Đã thanh toán' : ticket.status === 'pending' ? 'Chờ thanh toán' : 'Đã hủy'
                div.col-md-12
                  div.text-muted.small Mã vé
                  code= ticket._id

        div.col-lg-5
          div.card.border-0.shadow-sm
            div.card-body.p-4.text-center
              h5.fw-bold.mb-3 Mã QR vé
              if ticket.qrCode
                img.img-fluid.rounded.border(src=ticket.qrCode alt="Mã QR vé" style="max-width: 320px; width: 100%;")
                p.text-muted.small.mt-3.mb-0 Đưa mã QR này cho nhân viên check-in tại cổng sự kiện.
              else
                div.alert.alert-warning.mb-0 Chưa có mã QR cho vé này.
                